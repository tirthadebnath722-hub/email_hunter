def clean_and_validate(text, filter_domain=None):
    """কন্ডিশনাল ভ্যালিডেটর: সার্চ ইঞ্জিনে শুধু টার্গেট ফিল্টার করবে, আর মেইন সাইটে সব ক্যাচ করবে"""
    found = set()
    if not text:
        return found
    text = text.replace("[at]", "@").replace("(at)", "@").replace("[dot]", ".").replace("(dot)", ".")
    
    for email in EMAIL_REGEX.findall(text):
        email = email.lower().strip()
        # Strict validation checks
        if not email.endswith(BAD_EXTENSIONS) and not email.startswith(('.', '-', '_')):
            if not any(x in email for x in ['sentry', 'example', 'bootstrap', 'jquery', 'git', 'wp-content', 'assets', 'schemas']):
                if filter_domain:
                    # রিকোয়ারমেন্ট অনুযায়ী সার্চ ইঞ্জিনে শুধুমাত্র মেইন টার্গেট ডোমেইনের ইমেইল ফিল্টার হবে
                    if filter_domain in email:
                        found.add(email)
                else:
                    # রিকোয়ারমেন্ট অনুযায়ী মেইন সাইটের ভেতর মাদার কোম্পানি (@cbd.com) বা যেকোনো ইমেইল সব নিয়ে নেবে
                    found.add(email)
    return found

async def fetch(session, url, use_proxy=False):
    headers = {
        "User-Agent": random.choice(USER_AGENTS),
        "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8",
        "Accept-Language": "en-US,en;q=0.5",
        "Referer": "google.com"
    }
    proxy = random.choice(FREE_PROXIES) if use_proxy else None
    try:
        async with session.get(url, headers=headers, timeout=12, proxy=proxy, allow_redirects=True) as resp:
            if resp.status == 200:
                return await resp.text()
    except:
        # Fallback to no proxy if the free proxy node drops connection
        if use_proxy:
            try:
                async with session.get(url, headers=headers, timeout=8, allow_redirects=True) as resp:
                    if resp.status == 200:
                        return await resp.text()
            except:
                return ""
        return ""
    return ""

