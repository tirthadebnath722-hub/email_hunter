class AdvancedCrawler:
    def __init__(self, target_url, max_pages, concurrency):
        self.target_url = target_url
        self.domain = urlparse(target_url).netloc.replace("www.", "")
        if not self.domain:
            self.domain = urlparse(f"https://{target_url}").netloc.replace("www.", "")
        self.max_pages = max_pages
        self.semaphore = asyncio.Semaphore(concurrency)
        self.visited = set()
        self.emails = set()
        self.queue = set([target_url])

    async def crawl_page(self, session, url):
        if url in self.visited or len(self.visited) >= self.max_pages:
            return set()
        
        self.visited.add(url)
        print(f"[+] [Crawling Every Corner] -> {url}")
        
        async with self.semaphore:
            await asyncio.sleep(random.uniform(0.2, 0.4))
            html = await fetch(session, url, use_proxy=False)
            
        if not html:
            return set()
            
        new_links = set()
        
        # FIXED: Added native fallback string parsing to safeguard execution if system lacks lxml
        try:
            soup = BeautifulSoup(html, 'lxml')
        except Exception:
            soup = BeautifulSoup(html, 'html.parser')
        
        # মেইন সাইটের জন্য filter_domain=None (মুক্ত লজিক: মাদার কোম্পানি বা যেকোনো ডোমেইন সব ক্যাচ করবে)
        self.emails.update(clean_and_validate(html, filter_domain=None))
        
        for a_tag in soup.find_all('a', href=True):
            href = a_tag['href']
            # রিলেティブ ইউআরএলকে ফুল ইউআরএলে রূপান্তর
            full_url = urljoin(url, href)
            
            parsed_href = urlparse(full_url)
            if self.domain in parsed_href.netloc and full_url not in self.visited:
                if not any(x in full_url.lower() for x in ['/api/', 'oauth', 'authorize', 'login']):
                    if not full_url.lower().endswith(BAD_EXTENSIONS):
                        new_links.add(full_url)
        return new_links

    async def start(self, session):
        while self.queue and len(self.visited) < self.max_pages:
            # FIXED: Elements are popped directly from queue state to eliminate infinite memory leak traps
            current_batch = list(self.queue)[:10]
            self.queue.difference_update(current_batch)
            
            tasks = [asyncio.create_task(self.crawl_page(session, url)) for url in current_batch]
            results = await asyncio.gather(*tasks)
            for links in results:
                for link in links:
                    if link not in self.visited:
                        self.queue.add(link)

